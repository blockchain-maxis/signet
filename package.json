{
  "name": "signet",
  "private": true,
  "version": "0.0.0",
  "description": "Signet — a verifiable developer career record built on Stellar/Soroban.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:migrate": "pnpm --filter @signet/db run migrate",
    "db:generate": "pnpm --filter @signet/db run generate",
    "indexer:dev": "pnpm --filter @signet/indexer dev",
    "indexer:seed": "pnpm --filter @signet/indexer dev -- --reseed"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.16.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0"
  }
}
